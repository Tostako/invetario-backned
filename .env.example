# Server
PORT=3000
NODE_ENV=development

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars
