# Server
PORT=3000
NODE_ENV=development

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Mercado Pago (obligatorio; usar credenciales de prueba TEST-... en desarrollo)
MERCADOPAGO_ACCESS_TOKEN=TEST-tu_access_token_de_mercado_pago
