# ──────────────────────────────────────────────────────────────────────────────
# Variables de Entorno para Docker
# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a Git (ya está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════════
# Opción A: Supabase (recomendado para producción)
DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Opción B: PostgreSQL local (si usas el servicio docker-compose)
# DB_URL=postgresql://saas:saas123@postgres:5432/saas_db

# ═══════════════════════════════════════════════════════════════════════════════
# JWT
# ═══════════════════════════════════════════════════════════════════════════════
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria_aqui

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=[TU_ANON_KEY]
SUPABASE_SERVICE_ROLE=[TU_SERVICE_ROLE_KEY]

# ═══════════════════════════════════════════════════════════════════════════════
# MERCADO PAGO (opcional, solo si usas pagos)
# ═══════════════════════════════════════════════════════════════════════════════
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════════
# SERVIDOR
# ═══════════════════════════════════════════════════════════════════════════════
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# POSTGRESQL LOCAL (solo si usas el servicio postgres de docker-compose)
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_USER=saas
POSTGRES_PASSWORD=saas123
POSTGRES_DB=saas_db
